# .github/workflows/build.yml
name: Build & Upload LLVM 18 (aarch64-apple-darwin, no Homebrew)

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]
  workflow_dispatch:          # manual trigger for rebuilds

jobs:
  build-llvm:
    runs-on: macos-14         # M-series runner
    strategy:
      matrix:
        targets:
          - "AArch64;X86"    # adjust or expand as needed
    steps:
      - name: Checkout placeholder
        uses: actions/checkout@v4   # only to create llvm-rev.txt

      # ---------- 1. Cache the install tree ----------
      - name: Cache LLVM 18
        id: cache-llvm
        uses: actions/cache@v4
        with:
          path: llvm-18-install
          key: llvm-18-${{ matrix.targets }}-macos14-${{ hashFiles('llvm-rev.txt') }}

      # ---------- 2. One-time build (only on cache miss) ----------
      - name: Install build-deps
        if: steps.cache-llvm.outputs.cache-hit != 'true'
        run: brew install cmake ninja ccache

      - name: Clone & build LLVM 18
        if: steps.cache-llvm.outputs.cache-hit != 'true'
        run: |
          set -e
          git clone --depth=1 -b release/18.x https://github.com/llvm/llvm-project.git
          cd llvm-project
          git rev-parse HEAD > ../llvm-rev.txt

          cmake -S llvm -B build -G Ninja \
            -DCMAKE_BUILD_TYPE=Release \
            -DLLVM_ENABLE_PROJECTS="clang;lld" \
            -DLLVM_TARGETS_TO_BUILD="${{ matrix.targets }}" \
            -DCMAKE_INSTALL_PREFIX="$GITHUB_WORKSPACE/llvm-18-install" \
            -DCMAKE_C_COMPILER_LAUNCHER=ccache \
            -DCMAKE_CXX_COMPILER_LAUNCHER=ccache

          cmake --build build -j$(sysctl -n hw.ncpu)
          cmake --install build

      # ---------- 3. Upload the install tree as an artifact ----------
      - name: Upload LLVM 18 artifact
        uses: actions/upload-artifact@v4
        with:
          name: llvm-18-${{ matrix.targets }}-macos14
          path: llvm-18-install
          retention-days: 7          # keep for a week (adjust)
          compression-level: 9       # gzip tarball
